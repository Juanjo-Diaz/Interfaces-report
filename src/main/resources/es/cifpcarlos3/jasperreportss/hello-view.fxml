<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="16.0" xmlns:fx="http://javafx.com/fxml" fx:controller="es.cifpcarlos3.jasperreportss.MainController" >
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <HBox spacing="10.0" alignment="CENTER">
        <Label text="SPOTIFY" styleClass="brand" />
    </HBox>

    <Label text="Informe de Artistas por Género y Tipo de Medio" styleClass="title" />

    <HBox spacing="10.0" alignment="CENTER">
        <Label text="Género (P_GENRE_NAME):" />
        <TextField fx:id="txtGenre" promptText="Ej.: Rock" HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox spacing="10.0" alignment="CENTER">
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnGenerate" text="Generar informe" onAction="#onGenerateReport" />
        <Button fx:id="btnExit" text="Salir" onAction="#onExit" />
    </HBox>

    <Label fx:id="lblStatus" text="Estado: ..." />
</VBox>
